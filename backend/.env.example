# NeuroOffice Backend - Environment Variables
# Скопируйте этот файл в .env и заполните значения

PORT=3001

# OpenAI (опционально)
# OPENAI_API_KEY=sk-...

# Anthropic (опционально)
# ANTHROPIC_API_KEY=sk-ant-...

# Ollama (опционально)
# OLLAMA_ENDPOINT=http://localhost:11434

# LM Studio (опционально)
# LMSTUDIO_ENDPOINT=http://localhost:1234

# Groq (опционально, бесплатный тир - https://console.groq.com/)
# GROQ_API_KEY=gsk_...
