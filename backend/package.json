{
  "name": "neuro-office-backend",
  "version": "1.0.0",
  "description": "NeuroOffice Backend - быстрый и эффективный бэкенд для AI агентов",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "set NODE_OPTIONS=--experimental-vm-modules && jest",
    "test:watch": "set NODE_OPTIONS=--experimental-vm-modules && jest --watch",
    "test:coverage": "set NODE_OPTIONS=--experimental-vm-modules && jest --coverage"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "fuse.js": "^7.0.0",
    "uuid": "^9.0.1",
    "dotenv": "^16.4.1",
    "mammoth": "^1.6.0",
    "pdf-parse": "^1.1.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "@types/jest": "^29.5.12"
  }
}
